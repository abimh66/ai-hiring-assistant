# Shared across apps/agent-backend, apps/rag-backend, and apps/frontend (VITE_-prefixed only).
# Copy to .env at the repo root: cp .env.example .env

# --- frontend ---
VITE_API_BASE_URL=http://localhost:8000

# --- agent-backend ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hiring_assistant

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=["http://localhost:5173"]

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hiring-assistant
S3_REGION=us-east-1

RAG_BACKEND_URL=http://localhost:7777

# --- rag-backend ---
# OpenRouter (LLM gateway for resume_analysis_agent)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ID=openai/gpt-5-mini

# Mistral OCR (fallback for scanned/image-only PDFs)
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL_ID=mistral-ocr-latest

# Agno's own Postgres database (session/Studio storage — separate from hiring_assistant db)
AGNO_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agno

# ChromaDB
CHROMA_PATH=tmp/chroma
CHROMA_COLLECTION=resumes

# Extraction
OCR_MIN_CHARS_PER_PAGE=100
